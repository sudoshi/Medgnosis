# =============================================================================
# Medgnosis — Environment Configuration
# Copy to .env and fill in values for your environment.
# =============================================================================

# Database
DATABASE_URL=postgres://postgres:demosecret@localhost:5432/medgnosis

# Redis (BullMQ + WebSocket pub/sub)
REDIS_URL=redis://localhost:6379

# API Server
API_PORT=3002
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5175
# Canonical base URL for FHIR Bundle fullUrl construction (no trailing slash)
FHIR_BASE_URL=http://localhost:3002/api/fhir

# Auth (JWT)
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Provider: 'anthropic' (cloud, requires BAA) or 'ollama' (local, no BAA)
AI_PROVIDER=ollama
AI_INSIGHTS_ENABLED=false

# Anthropic (only used if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_BAA_SIGNED=false

# Ollama (local inference — no BAA required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:7b

# Email (Resend) — used for registration welcome emails and alerts
RESEND_API_KEY=
EMAIL_FROM=noreply@acumenus.net

# Web App URL (for email links)
WEB_APP_URL=http://localhost:5175

# Solr (search acceleration)
SOLR_ENABLED=false
SOLR_URL=http://localhost:8984/solr

# Observability
SENTRY_DSN=

# =============================================================================
# Docker Deployment
# These override defaults when running via docker compose.
# The installer or scripts/deploy.sh will set these automatically.
# =============================================================================

# Port nginx binds to on the host (Apache proxies to this)
NGINX_PORT=3081

# Internal service URLs (container-to-container via Docker network)
# Uncomment these when running in Docker:
# DATABASE_URL=postgresql://user:password@host.docker.internal:5432/medgnosis
# REDIS_URL=redis://redis:6379
# SOLR_URL=http://solr:8983/solr

# CORS must match the URL users access (nginx URL, not API directly)
# CORS_ORIGIN=http://localhost:3081

# Solr and Redis ports exposed to host (for debugging/admin)
SOLR_PORT=8984
REDIS_PORT=6379

# Measure evaluation engine: sql (star-schema aggregation) | cql (future cqf-ruler bridge)
MEASURE_EVALUATOR=sql
