# =============================================================================
# Medgnosis — Environment Configuration
# Copy to .env and fill in values for your environment.
# =============================================================================

# Database
DATABASE_URL=postgres://postgres:demosecret@localhost:5432/medgnosis

# Redis (BullMQ + WebSocket pub/sub)
REDIS_URL=redis://localhost:6379

# API Server
API_PORT=3002
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5175
# Canonical base URL for FHIR Bundle fullUrl construction (no trailing slash)
FHIR_BASE_URL=http://localhost:3002/api/fhir
# CQL clinical-reasoning sidecar. In Docker the api reaches it at
# http://cql-engine:8080/fhir; for host-dev run it with -p 18080:8080.
CQL_ENGINE_URL=http://localhost:18080/fhir
CQL_SAMPLE_COHORT_LIMIT=2000

# Auth (JWT)
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
LOCAL_AUTH_ENABLED=true
PUBLIC_REGISTRATION_ENABLED=false

# OIDC provider foundation. Local auth remains the default fallback.
OIDC_ENABLED=false
OIDC_LABEL=Authentik
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CLIENT_SECRET_REF=OIDC_CLIENT_SECRET
OIDC_REDIRECT_URI=http://localhost:3002/api/v1/auth/oidc/callback
OIDC_SCOPES=openid,profile,email,groups
OIDC_ALLOWED_GROUPS=Medgnosis Admins
OIDC_ADMIN_GROUPS=Medgnosis Admins
OIDC_STATE_TTL_SECONDS=300
OIDC_EXCHANGE_TTL_SECONDS=60

# AI Provider: 'anthropic' (cloud, requires BAA) or 'ollama' (local, no BAA)
AI_PROVIDER=ollama
AI_INSIGHTS_ENABLED=false

# Anthropic (only used if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_BAA_SIGNED=false

# Ollama (local inference — no BAA required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:7b

# Email (Resend) — used for registration welcome emails and alerts
RESEND_API_KEY=
EMAIL_FROM=noreply@acumenus.net

# Web App URL (for email links)
WEB_APP_URL=http://localhost:5175
# Browser realtime alert WebSocket. Set false for frontend-only E2E runs where
# the API websocket server is intentionally not started.
VITE_REALTIME_ALERTS_ENABLED=true

# Solr (search acceleration)
SOLR_ENABLED=false
SOLR_URL=http://localhost:8984/solr

# CDS Hooks POST authentication. Discovery remains public.
CDS_HOOKS_SECRET=
CDS_FHIR_AUTH_REQUIRED=false
CDS_SHARED_SECRET_COMPAT=true
CDS_JWKS_CACHE_TTL_SECONDS=300
CDS_FHIR_AUTH_ISSUER=
CDS_FHIR_AUTH_AUDIENCE=
CDS_FHIR_AUTH_JWKS_URL=
CDS_FHIR_AUTH_REQUIRED_SCOPES=

# EHR sandbox seed defaults for local SMART Health IT testing.
EHR_SANDBOX_ORG_ID=1
EHR_SMART_SANDBOX_CLIENT_ID=medgnosis-dev-smart-launch
EHR_SMART_SANDBOX_REDIRECT_URI=http://localhost:3002/api/v1/ehr/launch/callback
# Optional confidential SMART launch client secret target for registrations
# using client_secret_ref=env:EHR_SMART_CLIENT_SECRET.
EHR_SMART_CLIENT_SECRET=

# EHR onboarding profile/workbook generator. Use this before vendor app
# registration to produce redirect URI, launch URL, JWKS URL, scopes, and the
# follow-up ehr:onboard command.
EHR_PROFILE_VENDOR=
EHR_PROFILE_ENVIRONMENT=sandbox
EHR_PROFILE_NAME=
EHR_PROFILE_FHIR_BASE_URL=
EHR_PROFILE_API_BASE_URL=http://localhost:3002
EHR_PROFILE_TENANT_ID=
EHR_PROFILE_ORG_ID=
EHR_PROFILE_STATUS=testing
EHR_PROFILE_SMART_CLIENT_ID=
EHR_PROFILE_BACKEND_CLIENT_ID=
EHR_PROFILE_CDS_CLIENT_ID=
EHR_PROFILE_JSON=false

# EHR tenant/client onboarding CLI. These values can be supplied through env or
# equivalent --kebab-case CLI flags, for example:
# npm run ehr:onboard -- --vendor epic --environment sandbox --name "Epic Sandbox" --fhir-base-url https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4 --smart-client-id client-id --run-smoke
EHR_ONBOARD_VENDOR=
EHR_ONBOARD_ENVIRONMENT=sandbox
EHR_ONBOARD_NAME=
EHR_ONBOARD_FHIR_BASE_URL=
EHR_ONBOARD_TENANT_ID=
EHR_ONBOARD_ORG_ID=
EHR_ONBOARD_SMART_CONFIG_URL=
EHR_ONBOARD_ISSUER=
EHR_ONBOARD_AUDIENCE=
EHR_ONBOARD_STATUS=testing
EHR_ONBOARD_API_BASE_URL=http://localhost:3002
EHR_ONBOARD_JSON=false
EHR_ONBOARD_RUN_SMOKE=false
EHR_ONBOARD_SMART_CLIENT_ID=
EHR_ONBOARD_SMART_CLIENT_SLOT=smart_launch
EHR_ONBOARD_SMART_AUTH_METHOD=public_pkce
EHR_ONBOARD_SMART_PROFILE_ID=
EHR_ONBOARD_SMART_PROFILE_VERSION=
EHR_ONBOARD_SMART_PORTAL_APP_ID=
EHR_ONBOARD_SMART_APPROVAL_STATUS=draft
EHR_ONBOARD_SMART_APPROVAL_EVIDENCE_JSON=
EHR_ONBOARD_SMART_CLIENT_SECRET_REF=
EHR_ONBOARD_SMART_REDIRECT_URIS=
EHR_ONBOARD_SMART_LAUNCH_URL=
EHR_ONBOARD_SMART_SCOPES=
EHR_ONBOARD_SMART_GRANTED_SCOPES=
EHR_ONBOARD_SMART_ENABLED=true
EHR_ONBOARD_BACKEND_CLIENT_ID=
EHR_ONBOARD_BACKEND_CLIENT_SLOT=backend_services
EHR_ONBOARD_BACKEND_AUTH_METHOD=private_key_jwt
EHR_ONBOARD_BACKEND_PROFILE_ID=
EHR_ONBOARD_BACKEND_PROFILE_VERSION=
EHR_ONBOARD_BACKEND_PORTAL_APP_ID=
EHR_ONBOARD_BACKEND_APPROVAL_STATUS=draft
EHR_ONBOARD_BACKEND_APPROVAL_EVIDENCE_JSON=
EHR_ONBOARD_BACKEND_JWKS_URL=
EHR_ONBOARD_BACKEND_PRIVATE_KEY_REF=
EHR_ONBOARD_BACKEND_SCOPES=
EHR_ONBOARD_BACKEND_GRANTED_SCOPES=
EHR_ONBOARD_BACKEND_ENABLED=true
EHR_ONBOARD_CDS_CLIENT_ID=
EHR_ONBOARD_CDS_CLIENT_SLOT=cds_hooks
EHR_ONBOARD_CDS_AUTH_METHOD=fhir_authorization_jwt
EHR_ONBOARD_CDS_PROFILE_ID=
EHR_ONBOARD_CDS_PROFILE_VERSION=
EHR_ONBOARD_CDS_PORTAL_APP_ID=
EHR_ONBOARD_CDS_APPROVAL_STATUS=draft
EHR_ONBOARD_CDS_APPROVAL_EVIDENCE_JSON=
EHR_ONBOARD_CDS_CLIENT_SECRET_REF=
EHR_ONBOARD_CDS_JWKS_URL=
EHR_ONBOARD_CDS_SCOPES=
EHR_ONBOARD_CDS_GRANTED_SCOPES=
EHR_ONBOARD_CDS_ENABLED=true

# SMART Backend Services private-key refs should point to secret material, not
# raw keys in the DB. Example registration private_key_ref:
# env:EHR_BACKEND_PRIVATE_KEY_PEM?kid=backend-key-1&alg=RS384
EHR_BACKEND_PRIVATE_KEY_PEM=
# One-line private JWK JSON is easier for env files than multiline PEM. Generate
# with: npm run ehr:keygen -- --kid backend-key-1
EHR_BACKEND_PRIVATE_JWK_JSON=
# Public signing keys served at /.well-known/jwks.json for EHR validation.
# Configure either a full JWKS object or one public JWK object; do not include
# private JWK fields such as d, p, q, dp, dq, qi, oth, or k.
EHR_BACKEND_PUBLIC_JWKS_JSON=
EHR_BACKEND_PUBLIC_JWK_JSON=

# Backend-services patient-context refresh queue. Defaults to enabled outside
# test runs; set false to suppress enqueueing while Redis/backend credentials
# are being provisioned.
EHR_PATIENT_CONTEXT_REFRESH_QUEUE_ENABLED=true

# Bulk Data NDJSON import queue. Defaults to enabled outside test runs; set
# false while Redis/backend-services credentials are being provisioned.
EHR_BULK_IMPORT_QUEUE_ENABLED=true

# EHR onboarding smoke harness. FHIR reads and backend token exchange are opt-in
# because they call live EHR endpoints with real tokens/credentials.
EHR_SMOKE_TENANT_ID=
EHR_SMOKE_API_BASE_URL=http://localhost:3002
EHR_SMOKE_REQUEST_BACKEND_TOKEN=false
EHR_SMOKE_BACKEND_SCOPE=
EHR_SMOKE_ACCESS_TOKEN=
EHR_SMOKE_TOKEN_TYPE=Bearer
EHR_SMOKE_FHIR_READ=
EHR_SMOKE_JSON=false

# API docs. Defaults to false in production.
SWAGGER_ENABLED=true

# Observability
SENTRY_DSN=

# =============================================================================
# Docker Deployment
# These override defaults when running via docker compose.
# The installer or scripts/deploy.sh will set these automatically.
# =============================================================================

# Port nginx binds to on the host (Apache proxies to this)
NGINX_PORT=3081

# Internal service URLs (container-to-container via Docker network)
# Uncomment these when running in Docker:
# DATABASE_URL=postgresql://user:password@host.docker.internal:5432/medgnosis
# REDIS_URL=redis://redis:6379
# SOLR_URL=http://solr:8983/solr

# CORS must match the URL users access (nginx URL, not API directly)
# CORS_ORIGIN=http://localhost:3081

# Redis and Solr are internal-only in production docker-compose.yml.
# Use docker-compose.demo.yml for local host-published Redis/Solr ports, or
# docker compose exec for production troubleshooting.

# Measure evaluation engine: sql (star-schema aggregation) | cql (HAPI
# clinical-reasoning sidecar). Keep sql as the default authoritative path unless
# a measure has passed reconciliation and governance promotion.
MEASURE_EVALUATOR=sql

# -----------------------------------------------------------------------------
# EMPI probabilistic matching (SanteMPI) — Phase 1, OFF by default.
# Identity resolution is deterministic-only until you deploy the MPI sidecar
# (docker compose --profile mpi up -d santempi) and flip MPI_ENABLED=true.
# See docs/EMPI-SANTEMPI-SETUP.md.
# -----------------------------------------------------------------------------
MPI_ENABLED=false
MPI_BASE_URL=http://santempi:8080/fhir
# Must equal the master/enterprise identity assigning-authority OID configured
# in SanteMPI (the system of the identifier returned by Patient/$match).
MPI_MASTER_ID_SYSTEM=urn:oid:2.16.840.1.113883.3.999.mpi
# Optional bearer token if the MPI FHIR endpoint requires auth.
MPI_ACCESS_TOKEN=
# Preferred: OAuth2 client_credentials (machine-to-machine). For the bundled
# SanteMPI dev sidecar the seeded client fiddler/fiddler works:
#   MPI_TOKEN_URL=http://santempi:8080/auth/oauth2_token
#   MPI_CLIENT_ID=fiddler
#   MPI_CLIENT_SECRET=fiddler
MPI_TOKEN_URL=
MPI_CLIENT_ID=
MPI_CLIENT_SECRET=
MPI_SCOPE=*
# Score bands: auto-accept >= AUTO; route [REVIEW, AUTO) to steward queue.
MPI_AUTO_THRESHOLD=0.9
MPI_REVIEW_THRESHOLD=0.6
