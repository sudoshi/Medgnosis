{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "passThroughEnv": ["DATABASE_URL"]
    },
    "db:migrate:dry-run": {
      "cache": false,
      "passThroughEnv": ["DATABASE_URL"]
    },
    "db:migrate:list": {
      "cache": false,
      "passThroughEnv": ["DATABASE_URL"]
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:migrate"],
      "passThroughEnv": ["DATABASE_URL"]
    },
    "solr:reindex": {
      "cache": false,
      "passThroughEnv": ["DATABASE_URL", "SOLR_URL", "SOLR_AUTH_USER", "SOLR_AUTH_PASSWORD"]
    },
    "solr:cdc": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["DATABASE_URL", "SOLR_URL", "REDIS_URL", "SOLR_AUTH_USER", "SOLR_AUTH_PASSWORD"]
    }
  }
}
